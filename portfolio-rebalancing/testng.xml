<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CRD Portfolio Rebalancer Test Suite" verbose="2">

    <test name="1 - Portfolio Input and Validation" preserve-order="true">
        <classes>
            <class name="org.crd.tests.RebalanceCalculatorTest"/>
        </classes>
    </test>

    <test name="2 - Share Calculation" preserve-order="true">
        <classes>
            <class name="org.crd.tests.ShareCalculationTest"/>
        </classes>
    </test>

    <test name="3 - Zero Variance" preserve-order="true">
        <classes>
            <class name="org.crd.tests.ZeroVarianceTest"/>
        </classes>
    </test>

</suite>